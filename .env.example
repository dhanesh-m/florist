# Local development — optional `.env.local` for public site URL only.
# Admin login uses the `password` field on Firestore `adminContent/main` — no env secrets.

# Canonical site URL (metadata, OG). Use your live domain in production, e.g.:
# NEXT_PUBLIC_SITE_URL=https://www.floraldoctor.ca

# Firebase Hosting: set NEXT_PUBLIC_SITE_URL in the console if needed.
