# Local development — copy to `.env.local`
# Admin sign-in reads the plain-text `password` field on Firestore `adminContent/main` (same doc as site content).
ADMIN_SESSION_SECRET=use-openssl-rand-hex-32-min-16-chars

# Required for server-side Firestore (login + public site content API): service account JSON as one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Canonical site URL (metadata, OG). Use your live domain in production, e.g.:
# NEXT_PUBLIC_SITE_URL=https://www.floraldoctor.ca

# Firebase Hosting (production) — same keys as local; set in Firebase Console environment for the framework backend.
# Project id: see `.firebaserc` (default: floral-doctor). See `DEPLOY-FIREBASE.md`.
