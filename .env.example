# Local development — copy to `.env.local`
# Bootstrap: if Firestore has no password hash yet, this plain password matches login and is migrated to `adminAuth/main` (when Firebase Admin is configured).
# Or run: npm run seed:admin-password — with password from ADMIN_PASSWORD or first CLI arg.
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=use-openssl-rand-hex-32-min-16-chars

# Optional: Firebase Admin JSON (single line) — stores bcrypt password + reset tokens in Firestore `adminAuth/main`
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Forgot password: must match email saved in Firestore (set on first login from this env)
# ADMIN_EMAIL=you@example.com
# RESEND_API_KEY=re_...
# RESEND_FROM=Floral Doctor <onboarding@resend.dev>
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Firebase Hosting deploy (same keys; project id must match `.firebaserc`)
# Copy to `.env.floral-doctor` for `firebase deploy` (not committed to git)
# https://firebase.google.com/docs/functions/config-env
