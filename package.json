    "react-dom": "^18",
    "resend": "^6.10.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "firebase-tools": "^13.29.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
